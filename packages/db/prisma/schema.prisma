model EmailLog {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  municipalityId String      @map("municipality_id") @db.Uuid
  templateKey    String?     @map("template_key")
  toAddress      String      @map("to_address")
