# ─────────────────────────────────────────────────────────────────────────────
# Stan — environment variables (EXAMPLE). Copy to .env and fill real values.
# Never commit .env. Real values live only in Vercel / GitHub secret stores.
# See docs/deployment.md and docs/security.md.
# ─────────────────────────────────────────────────────────────────────────────

# ─── Database (Supabase PostgreSQL, EU region) ───────────────────────────────
# Pooled connection (PgBouncer) used by the serverless app.
DATABASE_URL="postgresql://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:6543/postgres?pgbouncer=true&connection_limit=1"
# Direct connection, used ONLY by Prisma migrations.
DIRECT_URL="postgresql://postgres:PASSWORD@db.YOUR-PROJECT.supabase.co:5432/postgres"

# ─── Supabase (Auth / Storage) ───────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL="https://YOUR-PROJECT.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-public-key"
# Server-only. NEVER expose to the client bundle.
SUPABASE_SERVICE_ROLE_KEY="your-service-role-secret-key"

# ─── App ─────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_APP_URL="http://localhost:3000"
