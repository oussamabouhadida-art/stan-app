  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)

  @@unique([municipalityId, number])
  @@index([childId])
  @@map("passport_jeunes")
}

/// SENSITIVE (Art. 9): gated by pai.* permissions; every read audited.
model Pai {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  municipalityId String    @map("municipality_id") @db.Uuid
  childId        String    @map("child_id") @db.Uuid
  child          Child     @relation(fields: [childId], references: [id])
  type           String
  startsOn       DateTime? @map("starts_on") @db.Date
  endsOn         DateTime? @map("ends_on") @db.Date
  details        Json?     @db.JsonB
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([childId])
  @@map("pais")
}

/// SENSITIVE (Art. 9): gated by handicap.* permissions; every read audited.
model HandicapFollowup {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  municipalityId String    @map("municipality_id") @db.Uuid
  childId        String    @map("child_id") @db.Uuid
  child          Child     @relation(fields: [childId], references: [id])
  details        Json?     @db.JsonB
  accommodations Json?     @db.JsonB
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([childId])
  @@map("handicap_followups")
}

/// Polymorphic owner (owner_type + owner_id) — see docs/database/design-review.md §4 (D4).
model Document {
  id             String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  municipalityId String    @map("municipality_id") @db.Uuid
  ownerType      String    @map("owner_type")
  ownerId        String    @map("owner_id") @db.Uuid
  type           String
  storagePath    String    @map("storage_path")
  fileName       String    @map("file_name")
  mimeType       String    @map("mime_type")
  sizeBytes      Int       @map("size_bytes")
  uploadedBy     String?   @map("uploaded_by") @db.Uuid
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime  @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  @@index([municipalityId, ownerType, ownerId])
  @@map("documents")
}

model Notification {
  id              String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  municipalityId  String    @map("municipality_id") @db.Uuid
  recipientUserId String    @map("recipient_user_id") @db.Uuid
  type            String
  payload         Json?     @db.JsonB
  readAt          DateTime? @map("read_at") @db.Timestamptz(6)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  @@index([recipientUserId, readAt])
  @@map("notifications")
}

model EmailTemplate {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  municipalityId String   @map("municipality_id") @db.Uuid
  key            String
  subject        String
  body           String
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

